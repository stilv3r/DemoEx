***Машина ISP
1. Настройка доменного имени
hostname
hostnamectl set-hostname isp.au-team.irpo

2. Настройка интерфейсов
ip a
( проврека ens3 {10.0.137.220/24 dynamic}; ens4 {172.16.1.1/28}; ens5 {172.16.2.1/28} ) <- если все так настройка не требуется

3. Настройка динамической транслации адресов
vim /etc/net/sysctl.conf
( искать net.ipv4.ip_forward = 1 } <- если все так настройка не требуется

iptables -t nat -L 
( должен отобразиться MASQUERADE all , если нету прописывать команды ниже и потом перепроверить командой выше )
iptables –t nat –A POSTROUTING –o ens3 –j MASQUERADE
iptables-save >> /etc/sysconfig/iptables
systemctl enable --now iptables

4. Настройка часового пояса
timedatectl
( будет преднастроенно )

5. Настройка сетевого времени chrony
chronyc sources
( должен отобразиться следующий ip 172.16.1.1 ) <- если другой ip-адрес, нужно настроить
vim /etc/chrony.conf
( искать { pool 172.16.1.1 iburst } если что-то другое написано изменять на данный ip )

***Машина HQ-RTR
1. Настройка доменного имени
en
conf t
hostname HQ-RTR
ip domain-name au-team.irpo
end
write memory

2. Настройка IP-адресов
show ip interface brief
( должна быть следующая преднастройка isp {172.16.1.2/28}; vl100 {10.10.100.1/27}; vl200 {10.10.200.1/28}; vl999 {10.10.30.1/29} )
преднастроен

3. Настройка пользователей
show users localdb
( должен быть добавлен {User: net_admin} )
преднастроен

4. Настройка GRE
( проверить show interface tunnel.0 - пусто прописываем команды )
en
conf t
interface tunnel.0
ip address 10.10.10.1/30
ip tunnel 172.16.1.2 172.16.2.2 mode gre
end
write memory

5. Настройка статической маршрутизации
( проверить show ip route - нет значение со *, значит не настроен )
conf t
ip route 0.0.0.0 0.0.0.0 172.16.1.1
end 
write memory

6. Настройка динамической маршрутизации (OSPF)
( проверить show ip route - нет буквы O, значит не настроен )
en
conf t
router ospf 0
network 10.10.100.0/27 area 0
network 10.10.200.0/28 area 0
network 10.10.30.0/29 area 0
network 10.10.10.0/30 area 0
passive-interface default
no passive-interface tunnel.0
area 0 authentication
exit
interface tunnel.0
ip ospf authentification message-digest
ip ospf message-digest-key 1 md5 P@ssw0rd 
end 
write memory

7. Настройка динамической трансляции адресов (NAT)
( проверить show ip nat translations - если пусто в строке Source, необходимо настроить )
en
conf t
interface isp
ip nat outside
exit
interface vl100
ip nat inside
exit
interface vl200
ip nat inside
exit
interface vl999
ip nat inside
exit
ip nat pool HQ 10.10.0.1-10.10.200.254
ip nat source dynamic inside-to-outside pool HQ overload interface isp
end 
write memory

8. Настройка протокола динамической конфигурации хостов (DHCP) 
( проверить show dhcp-server 1 detailed )
преднастроен

9. Настройка часового пояса
( проверить show ntp timezone - если пусто, необходимо настроить )
en
conf t
ntp timezone utc+3

