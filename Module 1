***Машина HQ-SRV
1. Настройка доменного имени
hostname
hostnamectl set-hostname hq-srv.au-team.irpo

2. Настройка интерфейсов
ip a
( проверка ens3 нет ip-адреса, необходимо настроить )
vim /etc/net/ifaces/ens3/options
 Проверить содержимое файла
 TYPE=eth
 CONFIG_WIRELESS=no
 BOOTPROTO=static
 SYSTEMD_BOOTPROTO=static
 CONFIG_IPV4=yes
 DISABLED=no
 NM_CONTROLLED=no
 SYSTEMD_CONTROLLED=no
 
vim /etc/net/ifaces/ens3/ipv4address
 Внести в файл информацию
 10.10.100.2/27

vim /etc/net/ifaces/ens3/ipv4route
 Внести в файл информацию
 default via 10.10.100.1

vim /etc/net/ifaces/ens3/resolv.conf
 Внести в файл информацию
 search au-team.irpo
 nameserver 77.88.8.8
 nameserver 127.0.0.1
 
systemctl restart network

3. Настройка локальной учетной записи
vim /etc/passwd
( проверить следующую строчку {sshuser:x:2026:501::/home/sshuser:/bin/bash} <- если все так настройка не требуется

vim /etc/group
( проверить следующую строчку {wheel:x:10:root,zabbix,user,sshuser} <- если все так настройка не требуется

vim +123 /etc/sudoers 
( WHEEL_USERS ALL=(ALL:ALL) NOPASSWD: ALL ) <- раскоментировать строчку, если стоит #

4. Настройка безопасноо удаленного доступа (SSH)
vim /etc/openssh/sshd_config
( проверить следущую строчку {MaxAuthTries 2} чтобы были попытки ввода пароля )
( найти следущую строчку {#Banner none} - нужно раскоментировать и вписать следующее {Banner /etc/openssh/banner} )

vim /etc/openssh/banner
 Внести в файл информацию
 Authorized access only
 
systemctl restart sshd

5. Настройте инфраструктуру разрешения доменных имён (DNS)
vim /etc/bind/rfc1912.conf
( проверить следующую строчку {zone "10.10.in-addr.arpa", file "10.10.in-addr.arpa", zone "au-team.irpo", file "au-team.irpo.zone"}

vim /etc/bind/zone/au-team.irpo.zone
( проверить следующую строчку {hq-srv.au-team.irpo. admin.au-team.irpo.} <- если написано так нужно исправить на -> {hq-srv.au-team.irpo. root.au-team.irpo.}

vim /etc/bind/zone/10.10.in-addr.arpa
( проверить следующую строчку {au-team.irpo root.auteam.itpo.} <- если написано так нужно исправить на -> {au-team.irpo. root.au-team.irpo.}

vim /etc/bind/options.conf
 Внести в файл изменения в следующих строчках
 listen-on { 10.10.100.2; };
 listen-on-v6 { none; };

 forwarders { 77.88.8.8; }; <- не забудь раскоментировать данную строчку, т.е. убрать в начале //

 allow-query { any; }; <- не забудь раскоментировать данную строчку, т.е. убрать в начале //

vim /etc/bind/zone/au-team.irpo.zone
( проверить следующую строчку {hq-srv.au-team.irpo. root.au-team.irpo.}
перепроверка

vim /etc/bind/zone/10.10.in-addr.arpa
( проверить следующую строчку {au-team.irpo. root.au-team.irpo.} ) 
перепроверка

6. Настройка часового пояса
timedatectl
преднастроен

